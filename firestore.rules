rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if record belongs to the user
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // User Profile Rules
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      // Sub-collections (Results & Chat)
      match /quiz_results/{resultId} {
        allow read, write: if isOwner(userId);
      }
      match /chat_history/{chatId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Global Statistics (Dashboard)
    match /stats/{statId} {
      allow read: if true; // Publicly readable for the landing page
      allow write: if false; // Only manageable via Cloud Functions or Admin SDK
    }
    
    // Fallback for development (Legacy logs - to be cleaned)
    match /results/{id} {
      allow read, write: if isAuthenticated();
    }
    match /chats/{id} {
      allow read, write: if isAuthenticated();
    }
  }
}
