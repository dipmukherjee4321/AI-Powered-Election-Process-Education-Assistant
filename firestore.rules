rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. User-specific data protection
    // Users can only read/write their own chat logs and quiz results
    match /chats/{chatId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    match /results/{resultId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    // 2. Global statistics (Read-only for public, Write-only for authenticated system)
    match /stats/{statId} {
      allow read: if true;
      allow write: if request.auth != null; // System-level updates or admin
    }
    
    // 3. User profiles
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
